rules_version = '2';

// Life Lessons — Firestore security rules
// Solo gabritupini@gmail.com e gabritupini3@gmail.com possono leggere/scrivere.
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthorized() {
      return request.auth != null &&
        request.auth.token.email in [
          'gabritupini@gmail.com',
          'gabritupini3@gmail.com'
        ];
    }

    match /pillars/{pillarId} {
      allow read, write: if isAuthorized();
    }

    match /lessons/{lessonId} {
      allow read, write: if isAuthorized();
    }

    match /study_nuances/{nuanceId} {
      allow read, write: if isAuthorized();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
