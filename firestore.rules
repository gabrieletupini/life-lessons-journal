rules_version = '2';

// Life Lessons — Firestore security rules
// Reads are PUBLIC on pillars / lessons / study_nuances so the read-only
// share mode works without authentication. Writes are still locked to the
// two authorized accounts.
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthorized() {
      return request.auth != null &&
        request.auth.token.email in [
          'gabritupini@gmail.com',
          'gabritupini3@gmail.com'
        ];
    }

    match /pillars/{pillarId} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    match /lessons/{lessonId} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    match /study_nuances/{nuanceId} {
      allow read: if true;
      allow write: if isAuthorized();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
